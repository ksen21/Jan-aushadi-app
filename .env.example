MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/jan-aushadi-finder
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# ── Frontend (repo root .env) ─────────────────────────────────────
# Local dev: http://localhost:8000
# Production: your Render backend URL, e.g. https://jan-aushadi-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Backend (server/.env) ─────────────────────────────────────────
# Text search: brand name -> generic name, via NaraRouter (free Claude-compatible router)
NARAROUTER_API_KEY=your_nararouter_api_key_here
NARAROUTER_TEXT_MODEL=claude-haiku-4.5
NARAROUTER_BASE_URL=https://router.bynara.id/v1

# Image search: medicine photo -> brand name, via Groq vision
GROQ_API_KEY=your_groq_api_key_here
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Live Kendra data source (Google Sheet published as CSV). Falls back to
# server/data/kendras.json if unset or unreachable.
KENDRA_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/your-sheet-id/pub?output=csv

# Comma-separated list of allowed frontend origins in production.
# localhost is always allowed automatically for local dev.
ALLOWED_ORIGINS=https://your-app.vercel.app
